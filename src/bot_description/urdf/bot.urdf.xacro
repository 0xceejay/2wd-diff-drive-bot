<?xml version="1.0"?>
<robot name="bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Base robot generated by onshape-to-robot -->
  <xacro:include filename="$(find bot_description)/urdf/bot.urdf"/>

  <!-- Gazebo friction, materials and diff drive plugin -->
  <xacro:include filename="$(find bot_description)/urdf/gazebo.xacro"/>


</robot>
